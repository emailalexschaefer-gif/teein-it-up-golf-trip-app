# ─────────────────────────────────────────────────────────────────────────────
# TEEIN' IT UP — Environment Variables
# Copy this file to .env.local and fill in your Supabase values.
# In Vercel: add these three variables under Project → Settings → Environment Variables.
# DO NOT add any other configuration — these three are all that is required.
# ─────────────────────────────────────────────────────────────────────────────

# From your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-side only, never exposed to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
